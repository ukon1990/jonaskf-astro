---
const { class: className = '' } = Astro.props;

const socials = [
  {
    id: 'email',
    href: 'mailto:hello@jonaskf.dev',
    label: 'Email',
    title: 'Send an email to Jonas',
    icon: {
      d: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v.217l8 5.053 8-5.053V6H4zm16 12V8.383l-7.445 4.7a1 1 0 0 1-1.11 0L4 8.383V18h16z',
    },
  },
  {
    id: 'github',
    href: 'https://github.com/jonaskf',
    label: 'GitHub',
    title: 'Visit Jonas on GitHub',
    external: true,
    icon: {
      d: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.011-1.04-.017-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.108-.776.418-1.304.762-1.604-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.468-2.381 1.235-3.22-.123-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23a11.52 11.52 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.654 1.653.242 2.873.12 3.176.77.839 1.233 1.91 1.233 3.22 0 4.61-2.807 5.624-5.48 5.92.43.372.823 1.102.823 2.222 0 1.604-.015 2.896-.015 3.286 0 .321.216.694.825.576C20.565 22.092 24 17.592 24 12.297 24 5.67 18.627.297 12 .297',
      fillRule: 'evenodd',
      clipRule: 'evenodd',
    },
  },
  {
    id: 'linkedin',
    href: 'https://www.linkedin.com/in/placeholder',
    label: 'LinkedIn',
    title: 'Connect with Jonas on LinkedIn',
    external: true,
    icon: {
      d: 'M20.452 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.446-2.136 2.939v5.667H9.356V9h3.413v1.561h.049c.476-.9 1.637-1.852 3.37-1.852 3.602 0 4.268 2.37 4.268 5.455v6.288zM5.337 7.433a2.062 2.062 0 1 1 0-4.123 2.062 2.062 0 0 1 0 4.123zM7.114 20.452H3.56V9h3.554v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.223 0h.002z',
    },
  },
];
---

<ul class:list={['social-links', className]}>
  {socials.map((social) => (
    <li>
      <a
        href={social.href}
        target={social.external ? '_blank' : undefined}
        rel={social.external ? 'noreferrer noopener' : undefined}
        title={social.title ?? social.label}
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
          <path
            d={social.icon.d}
            fill-rule={social.icon.fillRule}
            clip-rule={social.icon.clipRule}
          />
        </svg>
        <span>{social.label}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links {
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    list-style: none;
  }

  .social-links li {
    margin: 0;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    text-decoration: none;
    font-weight: 600;
    color: rgb(var(--gray-dark));
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: rgb(var(--accent));
  }

  .social-links svg {
    width: 1em;
    height: 1em;
    fill: currentColor;
    flex-shrink: 0;
  }

  .social-links span {
    line-height: 1;
  }
</style>
