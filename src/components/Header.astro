---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const hasPublishedPosts = (
	await getCollection('blog', ({ data }) => !data.draft)
).length > 0;
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/cv">Experience</HeaderLink>
			{hasPublishedPosts && <HeaderLink href="/blog">Blog</HeaderLink>}
		</div>
		<ul class="social-links">
			<li>
				<a href="mailto:hello@jonaskf.dev">Email</a>
			</li>
			<li>
				<a href="https://github.com/jonaskf" target="_blank" rel="noreferrer">GitHub</a>
			</li>
		</ul>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		margin: 0;
		padding: 0;
		display: flex;
		gap: 1rem;
		list-style: none;
	}
	.social-links a {
		text-decoration: none;
		font-weight: 600;
		color: rgb(var(--gray-dark));
	}
	.social-links a:hover {
		color: rgb(var(--accent));
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}
		.social-links {
			flex-wrap: wrap;
		}
	}
</style>
