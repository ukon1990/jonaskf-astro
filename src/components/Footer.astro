---
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer class="site-footer">
  <p>© {today.getFullYear()} Jonas Munthe Flønes.</p>
  <SocialLinks class="footer-social-links" justify="center" />
</footer>
<style>
  .site-footer {
    padding: 3.5rem 1rem 5rem 1rem;
    background: var(--surface-low);
    border-top: 1px solid var(--border-color);
    color: rgb(var(--gray));
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .footer-social-links {
    gap: 0.85rem;
    margin: 1rem 0 0 0;
  }
</style>
