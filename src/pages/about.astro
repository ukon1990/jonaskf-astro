---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Working with ${SITE_TITLE}`}
			description="How I approach product engineering engagements and collaborate with teams."
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 3rem 1rem 5rem 1rem;
			}
			main h1 {
				margin-bottom: 1rem;
			}
			main section + section {
				margin-top: 2rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Working together</h1>
			<p>
				I thrive when I can pair closely with product engineers, designers, and stakeholders to align
				on outcomes. My background spans greenfield platform work, large-scale rewrites, and focused
				enablement for teams that need to move faster without risking stability.
			</p>

			<section>
				<h2>What you can expect</h2>
				<ul>
					<li>Hands-on leadership across discovery, delivery, and operations.</li>
					<li>Strong emphasis on developer experience, observability, and pragmatic automation.</li>
					<li>Open communication, written updates, and visuals that keep everyone aligned.</li>
				</ul>
			</section>

			<section>
				<h2>How I engage</h2>
				<p>
					I typically embed with teams as a tech lead or staff engineer, mentoring while shipping. I am
					comfortable joining existing initiatives mid-flight or helping you shape a roadmap from the
					ground up.
				</p>
				<p>
					Need help? Say hello at <a href="mailto:hello@jonaskf.dev">hello@jonaskf.dev</a>.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
