---
import LocaleRedirect from '../../components/LocaleRedirect.astro';
import { getCollection } from 'astro:content';
import { slugFromCvEntryId } from '../../lib/i18n';

export async function getStaticPaths() {
	const entries = await getCollection('cv');
	const slugs = Array.from(new Set(entries.map((entry) => slugFromCvEntryId(entry.id))));
	return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
---

<LocaleRedirect path={`/cv/${slug}`} />
