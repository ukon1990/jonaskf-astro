---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import CvExperienceCard from '../../../components/CvExperienceCard.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';
import { getLocaleFromParams, ui, type Locale } from '../../../lib/i18n';

type CvEntry = CollectionEntry<'cv'>;

export function getStaticPaths() {
  return [{ params: { locale: 'no' } }, { params: { locale: 'en' } }];
}

const locale = getLocaleFromParams(Astro.params);
const labels = ui[locale].cv;
const sortExperiences = (a: CvEntry, b: CvEntry) => {
  const aProfessional = (a.data.capacity ?? 'professional') !== 'hobby';
  const bProfessional = (b.data.capacity ?? 'professional') !== 'hobby';
  if (aProfessional !== bProfessional) return aProfessional ? -1 : 1;
  return b.data.startDate.valueOf() - a.data.startDate.valueOf();
};

const allExperiences: CvEntry[] = (await getCollection('cv'))
  .filter((entry) => !entry.data.draft && entry.data.locale === locale)
  .sort(sortExperiences);

const searchPlaceholder =
  locale === 'no'
    ? 'Søk etter prosjekter, teknologier eller roller...'
    : 'Search projects, technologies, or roles...';
const searchLabel = locale === 'no' ? 'Søk i erfaringer' : 'Search engagements';
const emptySearchLabel =
  locale === 'no' ? 'Ingen erfaringer matcher søket.' : 'No engagements match your search.';
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={`${labels.title} — ${SITE_TITLE}`}
      description={`${ui[locale].siteDescription} ${labels.description}`}
      locale={locale as Locale}
    />
    <style>
      .hero {
        display: grid;
        gap: 1.75rem;
        max-width: 860px;
        margin: 0 auto 5.5rem;
      }
      .hero-header h1 {
        margin: 0;
      }
      .hero p {
        max-width: 46rem;
        margin: 0;
        color: rgb(var(--gray));
        font-size: 1.08rem;
      }
      .search-field {
        position: relative;
        max-width: 760px;
        margin-top: 1.2rem;
      }
      .search-field svg {
        position: absolute;
        top: 50%;
        left: 1.1rem;
        width: 1.2rem;
        height: 1.2rem;
        color: rgb(var(--gray));
        transform: translateY(-50%);
      }
      .search-field input {
        width: 100%;
        min-height: 3.5rem;
        padding: 0.85rem 1rem 0.85rem 3.1rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: var(--surface-low);
        color: rgb(var(--black));
        font: inherit;
        box-shadow: none;
      }
      .search-field input:focus-visible {
        border-color: var(--border-color-strong);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
        outline: none;
      }
      .projects-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .projects-grid :global(.experience-card) {
        min-height: 22rem;
      }
      .projects-grid :global(.experience-card .card-link) {
        display: flex;
        flex-direction: column;
        min-height: 100%;
      }
      .projects-grid :global(.experience-card h2) {
        font-size: 1.6rem;
      }
      .empty-state {
        margin: 3rem auto 0;
        padding: 1.5rem;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        color: rgb(var(--gray));
      }
      @media (max-width: 960px) {
        .hero {
          margin-bottom: 3rem;
        }
        .projects-grid {
          grid-template-columns: 1fr;
        }
        .projects-grid :global(.experience-card) {
          min-height: auto;
        }
        .projects-grid :global(.experience-card h2) {
          font-size: 1.45rem;
        }
      }
    </style>
  </head>
  <body>
    <Header locale={locale as Locale} />
    <main class="page-shell">
      <section class="hero" aria-label={labels.description} data-role="highlight-section">
        <header class="hero-header">
          <h1>
            {
              locale === 'no'
                ? 'Utvalgte arbeider og engasjementer'
                : 'Selected Works & Engagements'
            }
          </h1>
        </header>
        <p>{labels.description}</p>
        <label class="search-field">
          <span class="sr-only">{searchLabel}</span>
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <input type="search" placeholder={searchPlaceholder} data-project-search />
        </label>
      </section>

      <!-- CvExperienceFilters is intentionally not rendered for now; keep it available for a later filter UI. -->
      <section
        class="projects-grid"
        aria-label={labels.allEngagementsLabel}
        data-role="experience-list"
      >
        {
          allExperiences.map((experience) => (
            <CvExperienceCard experience={experience} variant="list" locale={locale as Locale} />
          ))
        }
      </section>

      <p class="empty-state" data-role="experience-empty" hidden>{emptySearchLabel}</p>
    </main>
    <Footer />

    <script type="module">
      (() => {
        const search = document.querySelector('[data-project-search]');
        const entries = Array.from(document.querySelectorAll('[data-search-index]'));
        const emptyState = document.querySelector("[data-role='experience-empty']");
        if (!search) return;

        const update = () => {
          const query = search.value.trim().toLowerCase();
          let visibleCount = 0;
          entries.forEach((entry) => {
            const visible = !query || (entry.dataset.searchIndex || '').includes(query);
            entry.hidden = !visible;
            if (visible) visibleCount += 1;
          });
          if (emptyState) emptyState.hidden = visibleCount > 0;
        };

        search.addEventListener('input', update);
        update();
      })();
    </script>
  </body>
</html>
