---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import portrait from '../../assets/headshot.jpeg';
import { SITE_TITLE } from '../../consts';
import { getTechDisplayName } from '../../data/tech';
import {
	getLocaleFromParams,
	formatPeriod,
	localizePath,
	slugFromCvEntryId,
	ui,
	type Locale,
} from '../../lib/i18n';

export function getStaticPaths() {
	return [{ params: { locale: 'no' } }, { params: { locale: 'en' } }];
}

const locale = getLocaleFromParams(Astro.params);
const labels = ui[locale];
const sortExperiences = (a: { data: { capacity?: string; startDate: Date } }, b: { data: { capacity?: string; startDate: Date } }) => {
	const aProfessional = (a.data.capacity ?? 'professional') !== 'hobby';
	const bProfessional = (b.data.capacity ?? 'professional') !== 'hobby';
	if (aProfessional !== bProfessional) return aProfessional ? -1 : 1;
	return b.data.startDate.valueOf() - a.data.startDate.valueOf();
};

const experiences = (await getCollection('cv'))
	.filter((entry) => !entry.data.draft && entry.data.locale === locale)
	.sort(sortExperiences)
	.slice(0, 3);

const posts =
	locale === 'en'
		? (await getCollection('blog'))
				.filter((entry) => !entry.data.draft)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
				.slice(0, 3)
		: [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={SITE_TITLE} description={labels.siteDescription} locale={locale as Locale} />
    <style>
      .hero {
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
        gap: 2rem;
        align-items: center;
      }
      .hero h1 {
        margin-bottom: 1rem;
      }
      .hero p {
        margin: 0 0 1rem 0;
      }
      .hero__content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .hero__figure {
        justify-self: end;
        border-radius: 16px;
        overflow: hidden;
        max-width: 280px;
        box-shadow: var(--box-shadow);
      }
      .hero__figure :global(img) {
        display: block;
        width: 100%;
        height: auto;
      }
      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
      }
      .section-header a {
        font-size: 0.95rem;
        font-weight: 600;
      }
      .experience-list,
      .post-list {
        display: grid;
        gap: 1.5rem;
      }
      .card h3 {
        margin-bottom: 0.35rem;
      }
      .summary {
        margin-top: 0.75rem;
        margin-bottom: 0;
      }
      .tags {
        margin: 1rem 0 0 0;
      }
      @media (max-width: 960px) {
        .hero {
          grid-template-columns: 1fr;
        }
        .hero__figure {
          justify-self: center;
        }
        .section-header {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <Header locale={locale as Locale} />
    <main class="page-shell page-grid page-grid--xl">
      <section class="hero" aria-labelledby="home-intro">
        <article class="hero__content">
          <h1 id="home-intro">{labels.home.introTitle}</h1>
          {labels.home.intro.map((paragraph) => <p>{paragraph}</p>)}
        </article>
        <figure class="hero__figure">
          <Image src={portrait} width={360} height={360} alt="Portrait" />
        </figure>
      </section>

      <section>
        <div class="section-header">
          <h2>{labels.home.experienceTitle}</h2>
          <a href={localizePath('/cv', locale)}>{labels.home.experienceLink} →</a>
        </div>
        <ul class="list-reset experience-list">
          {
            experiences.map((experience) => (
              <li class="card">
                <a class="card-link" href={localizePath(`/cv/${slugFromCvEntryId(experience.id)}`, locale)}>
                  <h3>{experience.data.title}</h3>
                  <p class="meta">
                    {experience.data.customer && <span>{experience.data.customer}</span>}
                    {experience.data.customer && ' · '}
                    {formatPeriod(experience.data.startDate, experience.data.endDate, locale)}
                  </p>
                  <p class="meta">
                    {experience.data.role}
                    {experience.data.employer && ` · ${experience.data.employer}`}
                  </p>
                  <p class="meta">
                    {experience.data.capacity === 'hobby'
                      ? labels.cv.hobby
                      : labels.cv.professional}
                  </p>
                  <p class="summary">{experience.data.summary}</p>
                  {experience.data.tech.length > 0 && (
                    <ul class="tags">
                      {experience.data.tech.slice(0, 4).map((tag) => (
                        <li>{getTechDisplayName(tag)}</li>
                      ))}
                    </ul>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      {
        posts.length > 0 && (
          <section>
            <div class="section-header">
              <h2>{labels.home.latestWritingTitle}</h2>
              <a href="/en/blog">{labels.home.latestWritingLink} →</a>
            </div>
            <ul class="list-reset post-list">
              {posts.map((post) => (
                <li class="card">
                  <a class="card-link" href={`/en/blog/${post.id}/`}>
                    <p class="meta">
                      <FormattedDate date={post.data.pubDate} locale={locale} />
                    </p>
                    <h3>{post.data.title}</h3>
                    <p class="summary">{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </main>
    <Footer />
  </body>
</html>
