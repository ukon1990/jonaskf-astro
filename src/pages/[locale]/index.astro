---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import portrait from '../../assets/headshot.jpeg';
import { SITE_TITLE } from '../../consts';
import { getTechDisplayName } from '../../data/tech';
import {
  getLocaleFromParams,
  formatPeriod,
  localizePath,
  slugFromCvEntryId,
  ui,
  type Locale,
} from '../../lib/i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'no' } }, { params: { locale: 'en' } }];
}

const locale = getLocaleFromParams(Astro.params);
const labels = ui[locale];
const sortExperiences = (
  a: { data: { capacity?: string; startDate: Date } },
  b: { data: { capacity?: string; startDate: Date } },
) => {
  const aProfessional = (a.data.capacity ?? 'professional') !== 'hobby';
  const bProfessional = (b.data.capacity ?? 'professional') !== 'hobby';
  if (aProfessional !== bProfessional) return aProfessional ? -1 : 1;
  return b.data.startDate.valueOf() - a.data.startDate.valueOf();
};

const experiences = (await getCollection('cv'))
  .filter((entry) => !entry.data.draft && entry.data.locale === locale)
  .sort(sortExperiences)
  .slice(0, 2);

const posts =
  locale === 'en'
    ? (await getCollection('blog'))
        .filter((entry) => !entry.data.draft)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .slice(0, 3)
    : [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={SITE_TITLE} description={labels.siteDescription} locale={locale as Locale} />
    <style>
      .hero {
        display: grid;
        grid-template-columns: minmax(260px, 460px) minmax(0, 1fr);
        gap: 4rem;
        align-items: center;
        min-height: 36rem;
      }
      .hero h1 {
        max-width: 12ch;
        margin-bottom: 1.25rem;
      }
      .hero p {
        max-width: 42rem;
        margin: 0 0 1rem 0;
        color: rgb(var(--gray));
        font-size: 1.05rem;
      }
      .hero__content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 1.25rem;
      }
      .hero__action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 0.8rem 1.35rem;
        border: 1px solid var(--border-color-strong);
        border-radius: 2px;
        background: rgb(var(--black));
        color: var(--card-background);
        font-family: 'Work Sans', 'Manrope', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-decoration: none;
        text-transform: uppercase;
      }
      .hero__action--secondary {
        background: transparent;
        color: rgb(var(--black));
      }
      .hero__figure {
        justify-self: start;
        border-radius: 8px;
        overflow: hidden;
        width: 100%;
        max-width: 460px;
        border: 1px solid var(--border-color);
        box-shadow: var(--box-shadow);
      }
      .hero__figure :global(img) {
        display: block;
        width: 100%;
        height: auto;
      }
      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      .section-header a {
        font-family: 'Work Sans', 'Manrope', sans-serif;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
      }
      .experience-list,
      .post-list {
        display: grid;
        gap: 2rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .experience-list .card {
        padding: 2rem;
        border-radius: 4px;
        box-shadow: 0 8px 28px rgba(26, 28, 28, 0.06);
      }
      .card h3 {
        margin: 1rem 0 0.7rem;
      }
      .summary {
        margin-top: 0.75rem;
        margin-bottom: 0;
        color: rgb(var(--gray));
      }
      .tags {
        margin: 1rem 0 0 0;
      }
      @media (max-width: 960px) {
        .hero {
          grid-template-columns: 1fr;
          gap: 2rem;
          min-height: auto;
        }
        .hero__figure {
          justify-self: center;
          order: -1;
        }
        .section-header {
          flex-direction: column;
          align-items: flex-start;
        }
        .experience-list,
        .post-list {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header locale={locale as Locale} />
    <main class="page-shell page-grid page-grid--xl">
      <section class="hero" aria-labelledby="home-intro">
        <figure class="hero__figure">
          <Image src={portrait} width={520} height={520} alt="Portrait" />
        </figure>
        <article class="hero__content">
          <h1 id="home-intro">{labels.home.introTitle}</h1>
          {labels.home.intro.map((paragraph) => <p>{paragraph}</p>)}
          <div class="hero__actions">
            <a class="hero__action" href={localizePath('/cv', locale)}>
              {locale === 'no' ? 'Se erfaring' : 'View resume'} →
            </a>
            <a class="hero__action hero__action--secondary" href={localizePath('/about', locale)}>
              {locale === 'no' ? 'Kontakt' : 'Contact me'}
            </a>
          </div>
        </article>
      </section>

      <section>
        <div class="section-header">
          <h2>{labels.home.experienceTitle}</h2>
          <a href={localizePath('/cv', locale)}>{labels.home.experienceLink} →</a>
        </div>
        <ul class="list-reset experience-list">
          {
            experiences.map((experience) => (
              <li class="card">
                <a
                  class="card-link"
                  href={localizePath(`/cv/${slugFromCvEntryId(experience.id)}`, locale)}
                >
                  <h3>{experience.data.title}</h3>
                  <p class="meta">
                    {experience.data.customer && <span>{experience.data.customer}</span>}
                    {experience.data.customer && ' · '}
                    {formatPeriod(experience.data.startDate, experience.data.endDate, locale)}
                  </p>
                  <p class="meta">
                    {experience.data.role}
                    {experience.data.employer && ` · ${experience.data.employer}`}
                  </p>
                  <p class="meta">
                    {experience.data.capacity === 'hobby'
                      ? labels.cv.hobby
                      : labels.cv.professional}
                  </p>
                  <p class="summary">{experience.data.summary}</p>
                  {experience.data.tech.length > 0 && (
                    <ul class="tags">
                      {experience.data.tech.slice(0, 4).map((tag) => (
                        <li>{getTechDisplayName(tag)}</li>
                      ))}
                    </ul>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      {
        posts.length > 0 && (
          <section>
            <div class="section-header">
              <h2>{labels.home.latestWritingTitle}</h2>
              <a href="/en/blog">{labels.home.latestWritingLink} →</a>
            </div>
            <ul class="list-reset post-list">
              {posts.map((post) => (
                <li class="card">
                  <a class="card-link" href={`/en/blog/${post.id}/`}>
                    <p class="meta">
                      <FormattedDate date={post.data.pubDate} locale={locale} />
                    </p>
                    <h3>{post.data.title}</h3>
                    <p class="summary">{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </main>
    <Footer />
  </body>
</html>
